### 2) Install VRseBuilder Unity MCP plugin 0.0.2

![image.png](attachment:b6559847-ae2f-4f4c-a71d-20bac862b609:image.png)

If you are in older versions of VRseBuilder ≤ 0.6.2  . You will get script compilation errors.

1. Replace the content of NodeTemplatesData.cs with below
    - Nodetemplatedata.cs
        
        ```jsx
        using System.Collections.Generic;
        using UnityEngine;
        
        namespace VRseBuilder.Tools.Editor
        {
            /*
                Node -> Name, TargetObject, Options, Data
                Options -> [Opt1, Opt2, Opt3]
                Opt1 -> Data (Param-1, Param-2, Param-3)
                Opt2 -> Data (Param-1, Param-2, Param-3)
                Opt3 -> Data (Param-1, Param-2, Param-3)
                Data -> [Param-1, Param-2, Param-3]
                Param-1 -> Key, Value, Type, DefaultValue
            */
        
            [CreateAssetMenu(fileName = "NodeTemplatesData", menuName = "Tools/VRseBuilder/SO/NodeTemplatesData")]
            public class NodeTemplatesData : ScriptableObject
            {
                [System.Serializable]
                public class ParameterData
                {
                    public string Key;
                    public string Type;
                    public string DefaultValue;
                    public string Description;
                    public ParameterData() { }
                    public ParameterData(string key, string type, string defaultValue, string description = "")
                    {
                        Key = key;
                        Type = type;
                        DefaultValue = defaultValue;
                        Description = description;
                    }
                }
        
                [System.Serializable]
                public class NestedParameterData
                {
                    public string Key;
                    public string Description;
                    public List<ParameterData> Parameters = new List<ParameterData>();
                }
        
                [System.Serializable]
                public class OptionData
                {
                    public string Name;
                    public string Description;
                    public List<ParameterData> Parameters = new List<ParameterData>();
                    public List<NestedParameterData> NestedParameters = new List<NestedParameterData>();
                }
        
                [System.Serializable]
                public class NodeData
                {
                    public string Name;
                    [Tooltip("Unique ID from backend (set after sync)")]
                    public string BackendId;
                    [Tooltip("Type: 'custom' or 'core'")]
                    public string Type = "core";
                    public string Description;
                    public GameObject TargetObject;
                    public List<OptionData> Options = new List<OptionData>();
                }
                public void OnValidate()
                {
                    _nodeTemplates.Clear();
                    _nodeTemplates.AddRange(actionTemplates);
                    _nodeTemplates.AddRange(triggerTemplates);
                }
        
                private List<NodeData> _nodeTemplates = new();
                public List<NodeData> AllNodeTemplates => _nodeTemplates;
                public List<NodeData> actionTemplates = new();
                public List<NodeData> triggerTemplates = new();
        
                // Field types for parameter type dropdown
                [Header("Field Type Configuration")]
                public List<string> fieldTypes = new List<string>
                {
                    "bool",
                    "int",
                    "float",
                    "string",
                    "stringMultiLine",
                    "intList",
                    "enumList",
                    "objectReference",
                };
        
                // Node types (for dropdown)
                public static readonly string[] NodeTypes = { "custom", "core" };
        
                public List<ParameterData> DefaultParameters { get; } = new List<ParameterData>()
                {
                    new ParameterData("targetRoleSetId", "int", "0")
                };
        
                public NodeData GetNodeTemplate(string nodeName)
                {
                    var nodeData = actionTemplates.Find(n => n.Name == nodeName);
                    return nodeData ?? triggerTemplates.Find(n => n.Name == nodeName);
                }
        
                public bool HasNodeTemplate(string nodeName)
                {
                    return _nodeTemplates.Exists(n => n.Name == nodeName);
                }
        
                public void AddNodeTemplate(NodeData nodeData)
                {
                    _nodeTemplates.Add(nodeData);
                }
        
                public void AddActionTemplate(NodeData actionData)
                {
                    actionTemplates.Add(actionData);
                }
        
                public void AddTriggerTemplate(NodeData triggerData)
                {
                    triggerTemplates.Add(triggerData);
                }
        
                public void RemoveNodeTemplate(string nodeName)
                {
                    _nodeTemplates.RemoveAll(n => n.Name == nodeName);
                }
            }
        }
        
        ```